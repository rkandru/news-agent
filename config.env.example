# Copy to config.env and edit. config.env is gitignored.

# Delivery target: the GitHub Gist id the daily digest file is written to.
GIST_ID="your_gist_id_here"
# Model used for the daily research run (alias or full id). sonnet is fast & plenty for this.
MODEL="sonnet"

# Paused email path (unused while delivering to gist):
SENDER_EMAIL="you@gmail.com"
RECIPIENT_EMAIL="you@gmail.com"
